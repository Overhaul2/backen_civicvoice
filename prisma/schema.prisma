generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  idCardNumber         String?        @unique
  phoneNumber          String?        @unique
  password             String
  role                 Role           @default(USER) @map("role_user")
  walletAddress        String?        @unique
  isVerified           Boolean        @default(false)
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  sessions             AuthSession[]
  createdConsultations Consultation[] @relation("AdminConsultations")
  createdEngagements   Engagement[]   @relation("AdminEngagements")
  votes                Vote[]
}

model AuthSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model Vote {
  id             String       @id @default(uuid())
  userId         String
  optionId       String
  consultationId String
  nullifier      String       @unique
  merkleLeaf     String?
  hashVote       String
  txHash         String?
  blockNumber    Int?
  createdAt      DateTime     @default(now())
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  option         Option       @relation(fields: [optionId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, consultationId])
}

model Engagement {
  id             String           @id @default(uuid())
  title          String
  description    String
  status         EngagementStatus @default(EN_ATTENTE)
  consultationId String
  creatorId      String
  hashEngagement String
  txHash         String?
  metadataURI    String?          @default("test")
  createdAt      DateTime         @default(now())
  consultation   Consultation     @relation(fields: [consultationId], references: [id])
  author         User             @relation("AdminEngagements", fields: [creatorId], references: [id])
}

model Consultation {
  id          String             @id @default(uuid())
  title       String
  imageUrl    String?
  description String
  status      ConsultationStatus @default(OUVERTE)
  creatorId   String
  startAt     DateTime           @default(now())
  endAt       DateTime
  createdAt   DateTime           @default(now())
  resultHash  String?
  creator     User               @relation("AdminConsultations", fields: [creatorId], references: [id])
  engagements Engagement[]
  options     Option[]
  votes       Vote[]
}

model Option {
  id             String       @id @default(uuid())
  label          String
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  votes          Vote[]
}

model BlockchainLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  hash        String
  txHash      String?
  blockNumber Int?
  network     String
  status      String
  explorerUrl String?
  createdAt   DateTime @default(now())
}

model MerkleRoot {
  id             String   @id @default(uuid())
  consultationId String
  rootHash       String
  txHash         String?
  createdAt      DateTime @default(now())
}

model ResultSnapshot {
  id             String   @id @default(uuid())
  consultationId String
  resultJson     Json
  resultHash     String
  txHash         String?
  createdAt      DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum EngagementStatus {
  EN_ATTENTE
  EN_COURS
  TERMINE
}

enum ConsultationStatus {
  OUVERTE
  FERMEE
  ARCHIVEE
}
