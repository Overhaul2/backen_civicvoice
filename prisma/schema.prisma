// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  idCardNumber String? @unique
  phoneNumber String? @unique
  password    String

  role          Role    @default(USER) @map("role_user")
  walletAddress String? @unique // lier identifiant de l'utilisateur à son adresse de portefeuille pour les interactions blockchain

  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions AuthSession[]
  votes    Vote[]

  createdConsultations Consultation[] @relation("AdminConsultations")
  createdEngagements   Engagement[]   @relation("AdminEngagements")
}

model AuthSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  refreshToken String  @unique
  userAgent    String?
  ipAddress    String?

  isRevoked Boolean @default(false)

  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Vote {
  id             String @id @default(uuid())
  userId         String
  optionId       String
  consultationId String

  nullifier  String  @unique // empêche double vote sans exposer userId
  merkleLeaf String? // pour arbre de Merkle

  hashVote    String //hash du vote
  txHash      String? //transaction blochaine
  blockNumber Int?
  createdAt   DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  option       Option       @relation(fields: [optionId], references: [id])
  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@unique([userId, consultationId])
}

model Engagement {
  id             String           @id @default(uuid())
  title          String
  description    String
  status         EngagementStatus @default(EN_ATTENTE)
  consultationId String
  creatorId      String

  hashEngagement String //hash de l'engagement
  txHash         String? //transaction blochaine

  author       User         @relation(fields: [creatorId], "AdminEngagements", references: [id])
  consultation Consultation @relation(fields: [consultationId], references: [id])

  createdAt DateTime @default(now())
}

model Consultation {
  id          String             @id @default(uuid())
  title       String
  imageUrl    String?
  description String
  status      ConsultationStatus @default(OUVERTE)

  creatorId   String
  creator     User               @relation("AdminConsultations", fields: [creatorId], references: [id])
  
  startAt     DateTime           @default(now())
  endAt       DateTime
  createdAt   DateTime           @default(now())

  resultHash  String?

  votes       Vote[]
  options     Option[]
  engagements Engagement[]
}

model Option {
  id             String       @id @default(uuid())
  label          String
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])

  votes Vote[]
}

model BlockchainLog {
  id         String  @id @default(uuid())
  entityType String // "vote" ou "engagement"
  entityId   String //id du vote ou de l'engagement

  hash       String
  txHash     String? //transaction blochaine

  blockNumber Int?

  network    String //"polygon", etc.
  status     String //ex: "pending", "confirmed", "failed"
  explorerUrl String? //lien vers l'explorateur de blockchain pour cette transaction

  createdAt DateTime @default(now())
}

model MerkleRoot {
  id             String   @id @default(uuid())
  consultationId String
  rootHash       String
  txHash         String?
  createdAt      DateTime @default(now())
}
//regrouper tous les votes  envoyer UN SEUL hash sur blockchain

model ResultSnapshot {
  id             String   @id @default(uuid())
  consultationId String
  resultJson     Json
  resultHash     String
  txHash         String?
  createdAt      DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  metadata  Json?

  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum EngagementStatus {
  EN_ATTENTE
  EN_COURS
  TERMINE
}

enum ConsultationStatus {
  OUVERTE
  FERMEE
  ARCHIVEE
}
